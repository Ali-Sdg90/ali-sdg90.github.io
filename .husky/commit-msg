#!/usr/bin/env sh

npm exec -- commitlint --edit "${1:-.git/COMMIT_EDITMSG}"
RESULT=$?

if [ $RESULT -ne 0 ]; then
  echo ""
  echo "Commit message format is invalid."
  echo "Please follow Conventional Commits: <type>(scope): <subject>"
  echo "Example: feat(portfolio): add interactive shelf"
  echo ""
  exit 1
fi
